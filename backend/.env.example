DATABASE_URL=postgresql://postgres:postgres@localhost:5433/urban_growth_mapper
CORS_ORIGINS=["http://localhost:5173"]

# Optional - only needed for scripts/ingest_sakarya_schools.py (one-time
# geocoding batch) and scripts/audit_pois_with_google_places.py. The rest
# of the app works with this unset.
GOOGLE_GEOCODING_API_KEY=

# Advisory chat (point-and-ask LLM analysis) - fully optional, the rest of
# the app is unaffected if left disabled or unreachable. Points at a local
# Ollama server by default; every field below is env-overridable to switch
# models or point at a remote API instead.
ADVISORY_LLM_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b
ADVISORY_LLM_TEMPERATURE=0.3
ADVISORY_LLM_TIMEOUT_SECONDS=300
